# --- App ---
# Canonical base URL of the deployment. Auth.js (v5) uses AUTH_URL to build
# OAuth callback URLs. Locally this is http://localhost:3000; on Vercel set it
# to your production URL, e.g. https://your-app.vercel.app
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
# Random secret for session/JWT encryption. Generate with: openssl rand -base64 32
AUTH_SECRET=

# --- Access control ---
# Comma-separated list of Google emails allowed to sign in.
# If empty, NOBODY can sign in (fails closed).
AUTH_WHITELIST=you@example.com,friend@example.com

# --- Google OAuth (Google Cloud Console > Credentials > OAuth client) ---
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
# (Google accepts http://localhost and http://127.0.0.1 for local dev.)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Spotify OAuth (developer.spotify.com/dashboard) ---
# Redirect URI: {AUTH_URL}/api/auth/callback/spotify
# NOTE: Spotify rejects "localhost"; it only allows the loopback IP 127.0.0.1
# or HTTPS. Next.js normalizes loopback IPs to "localhost" in local dev, so
# Spotify login only works on a real HTTPS deployment (e.g. Vercel), not local.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- MongoDB ---
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=spotify_playlist_builder

# --- OpenAI ---
OPENAI_API_KEY=
# Optional. Defaults to gpt-4o-mini. Use a model that supports JSON schema responses.
OPENAI_MODEL=gpt-4o-mini
