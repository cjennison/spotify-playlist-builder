# --- App ---
# Base URL of the deployment (used by Auth.js for OAuth callbacks)
NEXTAUTH_URL=http://localhost:3000
# Random secret for session/JWT encryption. Generate with: openssl rand -base64 32
AUTH_SECRET=

# --- Access control ---
# Comma-separated list of Google emails allowed to sign in.
# If empty, NOBODY can sign in (fails closed).
AUTH_WHITELIST=you@example.com,friend@example.com

# --- Google OAuth (Google Cloud Console > Credentials > OAuth client) ---
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Spotify OAuth (developer.spotify.com/dashboard) ---
# Redirect URI: {NEXTAUTH_URL}/api/auth/callback/spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- MongoDB ---
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=spotify_playlist_builder

# --- OpenAI ---
OPENAI_API_KEY=
# Optional. Defaults to gpt-4o-mini. Use a model that supports JSON schema responses.
OPENAI_MODEL=gpt-4o-mini
